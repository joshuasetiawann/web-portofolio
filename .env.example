# ---------------------------------------------------------------------------
# Public (exposed to the browser — safe, non-secret)
# ---------------------------------------------------------------------------
# Canonical production origin (no trailing slash). Used for metadata, OG, sitemap.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Display name used across metadata and structured data.
NEXT_PUBLIC_SITE_NAME="Joshua Setiawan"
# GitHub username powering the Open Source page + GitHub Dashboard.
NEXT_PUBLIC_GITHUB_USERNAME="joshuasetiawann"

# ---------------------------------------------------------------------------
# Server (secret — never exposed to the client). All optional in the
# foundation; features that need them are wired in later phases.
# ---------------------------------------------------------------------------
# Personal access token to raise GitHub API rate limits (read-only / public scope).
GITHUB_TOKEN=""
# Resend API key for the contact form. Without it, submissions are validated
# and logged server-side but no email is sent.
RESEND_API_KEY=""
# Destination inbox for contact submissions (defaults to the site email).
CONTACT_TO_EMAIL=""
# Verified sender identity. Defaults to Resend's onboarding address, which only
# delivers to the Resend account owner — set this once a domain is verified.
CONTACT_FROM_EMAIL=""
